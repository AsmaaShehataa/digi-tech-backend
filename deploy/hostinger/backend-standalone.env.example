# Standalone backend environment example
# Use this when backend runs in a separate repository/service.

APP_PORT=5000
FLASK_DEBUG=0
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# public or admin_internal
APP_DEPLOY_TARGET=public

# Admin credentials (used in admin_internal mode)
ADMIN_EMAIL=admin@digi-tech.com
ADMIN_PASSWORD=replace-me
# ADMIN_PASSWORD_HASH=

# Optional app-level admin IP allowlist in CIDR format
# ADMIN_ALLOWED_IPS=203.0.113.10/32,198.51.100.0/24

# CORS allowlist for public APIs
# Use "*" only if you intentionally want open access
PUBLIC_API_ALLOWED_ORIGINS=https://www.digi-tech.com,https://digi-tech.com

# Set to 1 only when browser credentials are needed cross-origin
PUBLIC_API_ALLOW_CREDENTIALS=0
