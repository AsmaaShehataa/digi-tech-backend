[Unit]
Description=Digi-Tech Public Web/API Service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/digi-tech
EnvironmentFile=/etc/digi-tech/public.env
ExecStart=/usr/bin/python3 /var/www/digi-tech/admin_backend.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
