APP_DEPLOY_TARGET=admin_internal
APP_PORT=5001
FLASK_SECRET_KEY=replace-with-strong-secret
DATABASE_URL=postgresql://user:password@host:5432/database
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-strong-password
# Alternative to ADMIN_PASSWORD:
# ADMIN_PASSWORD_HASH=<werkzeug-generated-hash>

# Limit access to office/home/VPN IP ranges
ADMIN_ALLOWED_IPS=203.0.113.44/32,198.51.100.0/24
